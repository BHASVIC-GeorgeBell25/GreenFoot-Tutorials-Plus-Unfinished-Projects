public class Button extends Actor {  
    private GreenfootImage button_1 = new GreenfootImage("Circle.png");  
    private GreenfootImage button_2 = new GreenfootImage("Circle2.png");  
    private GreenfootImage button_3 = new GreenfootImage("Circle3.png");
    boolean mouseDown = false;
    public Button() {  
        //         setImage(null);  
    }  

    public void act() {  
        Buttons mySpecialWorld_YAY = (Buttons)getWorld();
        if (!mouseDown && Greenfoot.mousePressed(this)) {    
            setImage(button_3);
            mouseDown = true;
        }
        if (Greenfoot.mouseClicked(null)) {
            mouseDown = false;
            setImage(button_1);
        }        
        //         else{
        //             setImage(button_1);
        //             // mouseDown = false;
        //         }
        if (Greenfoot.mouseClicked(this)) {  
            //             setImage(button_1);
            mouseDown = false;
            mySpecialWorld_YAY.setClicked(true);
        }  
        if (mySpecialWorld_YAY.getDaPage()==true) {
            setImage(button_1);
//             mySpecialWorld_YAY.changePage(false);
        }
    }    
}
